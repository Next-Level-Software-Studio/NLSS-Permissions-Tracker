#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

def inicialize(file_path=None, folder_path=None):
    if folder_path is None:
        print("[Warning] No permissions folder specified. Using CWD.")
        folder_path = Path('.').resolve()
    if file_path is None:
        print("[Warning] No permissions file specified. Using default.")
        file_path = folder_path / ".permissions"
    return folder_path, file_path
    
def commit(file_path, folder_path):
    folder_path, file_path = inicialize()
    print(f'Saving permissions from folder: "{folder_path}", to file: "{file_path}"...')

def apply(file_path, folder_path):
    folder_path, file_path = inicialize()
    print(f'Applying permissions from file: "{file_path}", to folder: "{folder_path}"...')

def main():
    parser = argparse.ArgumentParser(description="Automation script, for applying and saving files and folders permissions.")
    
    parser.add_argument("command", nargs="?", choices=["commit", "apply", "help"], default="help", help="")
    parser.add_argument("--file", type=str, default=None, help="")
    parser.add_argument("--folder", type=str, default=None, help="")
    
    args = parser.parse_args()

    if args.command == "help":
        if args.file is not None or args.folder is not None:
            print("[ERROR] The 'help' command does not accept --file or --folder flags.")
            parser.print_usage()
            sys.exit(1)
        parser.print_help()
        sys.exit(0)
        
    if args.command == "apply" and args.folder is None:
        parser.error("the following arguments are required: --folder")

    if args.command == "commit":
        commit(args.file, args.folder)
    elif args.command == "apply":
        apply(args.file, args.folder)

if __name__ == "__main__":
    main()