#!/usr/bin/env python3
import argparse
import sys
from pathlib import Path

def commit(file_path, folder_path):
    if file_path is None:
        print("[Warning] No permissions file specified. Using default.")
        file_path = Path('.').resolve() / ".permissions"
    if folder_path is None:
        folder_path = Path(file_path).parent
    print(f'Saving permissions from folder: "{folder_path}", to file: "{file_path}"...')

def apply(file_path, folder_path):
    if file_path is None:
        print("[Warning] No permissions file specified. Using default.")
        file_path = Path('.').resolve() / ".permissions"
    if folder_path is None:
        folder_path = Path(file_path).parent
    print(f'Applying permissions from file: "{file_path}", to folder: "{folder_path}"...')

def main():
    parser = argparse.ArgumentParser(description="Automation script for Commit and Apply processes.")
    
    parser.add_argument("command", nargs="?", choices=["commit", "apply", "help"], default="help", help="Choose the desired command. If omitted, displays this help screen.")
    parser.add_argument("--file", type=str, default=None, help="[Optional] File path for commit or apply commands.")
    parser.add_argument("--folder", type=str, default=None, help="Folder path. Required for apply, optional for commit.")
    
    args = parser.parse_args()

    if args.command == "help":
        if args.file is not None or args.folder is not None:
            print("[ERROR] The 'help' command does not accept --file or --folder flags.")
            parser.print_usage()
            sys.exit(1)
        parser.print_help()
        sys.exit(0)
        
    if args.command == "apply" and args.folder is None:
        parser.error("the following arguments are required: --folder")

    if args.command == "commit":
        commit(args.file, args.folder)
    elif args.command == "apply":
        apply(args.file, args.folder)

if __name__ == "__main__":
    main()